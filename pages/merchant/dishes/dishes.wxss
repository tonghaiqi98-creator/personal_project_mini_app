.dishes-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 22rpx;
}

.create-button {
  width: 156rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #D77A32;
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 700;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  padding: 28rpx;
}

.summary-value {
  color: #222222;
  font-size: 38rpx;
  font-weight: 800;
}

.summary-label {
  margin-top: 8rpx;
  color: #777777;
  font-size: 26rpx;
}

.dish-card {
  display: flex;
  gap: 20rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}

.dish-image {
  width: 150rpx;
  height: 150rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #EEEEEE;
}

.dish-main {
  flex: 1;
  min-width: 0;
}

.dish-name {
  color: #222222;
  font-size: 30rpx;
  font-weight: 700;
}

.dish-meta,
.dish-desc,
.option-text {
  margin-top: 8rpx;
  color: #777777;
  font-size: 24rpx;
  line-height: 1.45;
}

.option-text {
  color: #999999;
}

.dish-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 12rpx;
}

.status {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status.on {
  background: #FFF3EA;
  color: #D77A32;
}

.status.off {
  background: #EEEEEE;
  color: #777777;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 18rpx;
}

.action-button {
  width: 132rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #D77A32;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.action-button.secondary {
  background: #FFF3EA;
  color: #D77A32;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  background: rgba(0, 0, 0, 0.28);
}

.option-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  padding: 34rpx 32rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #FFFFFF;
  box-sizing: border-box;
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 26rpx;
}

.sheet-title {
  color: #222222;
  font-size: 34rpx;
  font-weight: 800;
}

.sheet-desc {
  margin-top: 8rpx;
  color: #777777;
  font-size: 24rpx;
}

.sheet-close {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  border-radius: 50%;
  background: #F7F7F7;
  color: #777777;
  font-size: 40rpx;
  text-align: center;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option-chip {
  min-width: 112rpx;
  height: 62rpx;
  line-height: 62rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #F7F7F7;
  color: #777777;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.option-chip.active {
  background: #FFF3EA;
  color: #D77A32;
}

.option-chip.add {
  border: 1rpx dashed #D77A32;
  background: #FFFFFF;
  color: #D77A32;
}

.save-options-button {
  width: 100%;
  margin-top: 30rpx;
}

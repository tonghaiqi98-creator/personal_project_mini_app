.detail-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.status-card {
  padding: 36rpx 32rpx;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #FFF3EA;
  color: #D77A32;
  font-size: 24rpx;
  font-weight: 700;
}

.status-title {
  margin-top: 24rpx;
  color: #222222;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.status-desc {
  margin-top: 12rpx;
  color: #777777;
  font-size: 26rpx;
}

.info-card,
.remark-card,
.summary-card {
  margin-top: 24rpx;
  padding: 28rpx 30rpx;
}

.info-row,
.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 18rpx;
  font-size: 27rpx;
}

.info-row:last-child,
.summary-row:last-child {
  margin-bottom: 0;
}

.info-label,
.summary-row {
  color: #777777;
}

.info-value {
  min-width: 0;
  color: #222222;
  font-weight: 600;
  text-align: right;
  word-break: break-all;
}

.section-title-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 36rpx 0 18rpx;
}

.items-card {
  padding: 8rpx 28rpx;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.order-item:last-child {
  border-bottom: 0;
}

.item-image {
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #EEEEEE;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  color: #222222;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.item-meta {
  margin-top: 8rpx;
  color: #777777;
  font-size: 24rpx;
}

.item-spec {
  margin-top: 6rpx;
  color: #999999;
  font-size: 22rpx;
}

.item-subtotal {
  flex-shrink: 0;
  color: #222222;
  font-size: 28rpx;
  font-weight: 700;
}

.remark-label {
  color: #222222;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.remark-text {
  color: #777777;
  font-size: 26rpx;
  line-height: 1.5;
}

.total-row {
  color: #222222;
  font-weight: 700;
}

.bottom-action {
  margin-top: 36rpx;
}

.action-button,
.empty-button {
  width: 100%;
}

.empty-card {
  margin-top: 160rpx;
  padding: 48rpx 36rpx;
  text-align: center;
}

.empty-title {
  color: #222222;
  font-size: 34rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: #777777;
  font-size: 26rpx;
}

.empty-button {
  margin-top: 32rpx;
}

.history-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.head-button {
  width: 148rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #FFF3EA;
  color: #D77A32;
  font-size: 26rpx;
  font-weight: 700;
}

.head-button-hover {
  background: #FFE6D2;
}

.order-card {
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
}

.order-card:active {
  opacity: 0.92;
}

.order-top,
.order-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.order-no {
  color: #222222;
  font-size: 28rpx;
  font-weight: 700;
}

.order-time {
  margin-top: 6rpx;
  color: #777777;
  font-size: 24rpx;
}

.status-pill {
  flex-shrink: 0;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  background: #FFF3EA;
  color: #D77A32;
  font-size: 23rpx;
  font-weight: 700;
}

.order-body {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #EEEEEE;
}

.order-store {
  color: #222222;
  font-size: 28rpx;
  font-weight: 700;
}

.order-summary {
  margin-top: 8rpx;
  color: #777777;
  font-size: 25rpx;
  line-height: 1.45;
}

.order-bottom {
  margin-top: 24rpx;
}

.order-count {
  color: #777777;
  font-size: 24rpx;
}

.empty-card {
  margin-top: 120rpx;
  padding: 48rpx 36rpx;
  text-align: center;
}

.empty-title {
  color: #222222;
  font-size: 34rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: #777777;
  font-size: 26rpx;
}

.empty-button {
  width: 100%;
  margin-top: 32rpx;
}

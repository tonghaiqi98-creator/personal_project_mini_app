.cart-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.store-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx 32rpx;
}

.store-label {
  color: #777777;
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.store-table {
  color: #222222;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.store-name {
  flex-shrink: 0;
  color: #D77A32;
  font-size: 28rpx;
  font-weight: 700;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  margin: 36rpx 0 18rpx;
}

.clear-action,
.remove-action {
  color: #777777;
  font-size: 24rpx;
}

.cart-list {
  padding: 4rpx 28rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.cart-item:last-child {
  border-bottom: 0;
}

.cart-item:active {
  opacity: 0.92;
}

.item-image {
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #EEEEEE;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-name {
  color: #222222;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.item-spec {
  margin-top: 6rpx;
  color: #999999;
  font-size: 22rpx;
}

.item-price {
  margin-top: 8rpx;
  color: #D77A32;
  font-size: 28rpx;
  font-weight: 700;
}

.item-side {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.item-subtotal {
  color: #222222;
  font-size: 28rpx;
  font-weight: 700;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  padding: 0;
  border-radius: 50%;
  background: #F7F7F7;
  color: #D77A32;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.quantity-btn.plus {
  background: #D77A32;
  color: #FFFFFF;
}

.quantity-text {
  min-width: 34rpx;
  color: #222222;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.empty-card {
  padding: 48rpx 36rpx;
  text-align: center;
}

.empty-title {
  color: #222222;
  font-size: 34rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: #777777;
  font-size: 26rpx;
}

.empty-button {
  margin-top: 30rpx;
}

.summary-card {
  margin-top: 24rpx;
  padding: 28rpx 30rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #777777;
  font-size: 28rpx;
  margin-bottom: 18rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.total-row {
  color: #222222;
  font-weight: 700;
}

.bottom-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.continue-button {
  flex: 1;
}

.checkout-button {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  border-radius: 48rpx;
  background: #D77A32;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
}

.checkout-hover {
  background: #C96E2A;
}

.checkout-button.disabled {
  background: #DDDDDD;
  color: #999999;
  box-shadow: none;
}
